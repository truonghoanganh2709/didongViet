PORT=5000
NODE_ENV=development

# --- MongoDB Atlas (cách 3) ---
# Thay USER, PASSWORD, cluster host từ Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/didongviet?retryWrites=true&w=majority

# --- MongoDB local (nếu dùng Docker / cài máy) ---
# MONGODB_URI=mongodb://127.0.0.1:27017/didongviet

JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRE=7d
CLIENT_URL=http://localhost:5173
